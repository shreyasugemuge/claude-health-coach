# Framework .gitignore
# Aggressive: this repo must NEVER track personal data.
# The personal vault has its own (looser) gitignore for backup purposes.

# macOS
.DS_Store
._*

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/

# Node
node_modules/

# === PERSONAL-DATA PATHS (never in framework) ===
# Anchored to repo root so sanitized fixtures under examples/ remain trackable.
/wiki/profile/
/wiki/biomarkers/
/wiki/logs/
/wiki/targets/
/wiki/plans/
/wiki/food-library/
/wiki/calendar/
/wiki/reviews/
/wiki/design/
/raw/

# === VAULT-SPECIFIC FILES (never in framework) ===
.is-personal-vault
hot.md
index.md
log.md

# Local overrides
*.local.md
*.local.*
.local/
