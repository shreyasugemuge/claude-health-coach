#!/bin/sh
# Vault pre-commit: sanity-check that nothing framework-shaped is being
# committed into the personal vault. This is the inverse of the framework's
# own pre-commit, which blocks personal-data paths.
#
# Install: see ./install.sh in this directory.

set -e

# Refuse to commit if this hook is running inside a framework checkout by
# mistake (no .is-personal-vault marker present).
if [ ! -f ".is-personal-vault" ]; then
  echo "❌ vault pre-commit: .is-personal-vault marker missing." >&2
  echo "   This hook is intended for the personal vault, not the framework." >&2
  exit 1
fi

# Block staging of framework files as regular files (they must remain symlinks).
# Symlinks show up in git as mode 120000; regular files as 100644. If somebody
# accidentally `cp`-ed a framework file in, this catches it.
staged=$(git diff --cached --name-only --diff-filter=ACM)
for path in CLAUDE.md llm-wiki.md; do
  if printf '%s\n' "$staged" | grep -qx "$path"; then
    mode=$(git ls-files --stage -- "$path" | awk '{print $1}')
    if [ "$mode" != "120000" ]; then
      echo "❌ vault pre-commit: $path is staged as a regular file, not a symlink." >&2
      echo "   Restore the symlink to your framework checkout, then re-stage." >&2
      exit 1
    fi
  fi
done

exit 0
